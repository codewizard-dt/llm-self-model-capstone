        "heading"
      ],
      "title": "AprilTagPose",
      "type": "object"
    },
    "ContractSource": {
      "additionalProperties": false,
      "properties": {
        "brain_end_ms": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Brain End Ms"
        },
        "brain_start_ms": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Brain Start Ms"
        },
        "pi_received_ms": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Pi Received Ms"
        },
        "raw_session_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Raw Session Path"
        },
        "telemetry_sample_count": {
          "minimum": 0,
          "title": "Telemetry Sample Count",
          "type": "integer"
        }
      },
      "required": [
        "telemetry_sample_count"
      ],
      "title": "ContractSource",
      "type": "object"
    },
    "MotorApiSample": {
      "additionalProperties": false,
      "properties": {
        "api_binding": {
          "const": "vexcode_python",
          "default": "vexcode_python",
          "title": "Api Binding",
          "type": "string"
        },
        "device": {
          "title": "Device",
          "type": "string"
        },
        "sample_ms": {
          "minimum": 0,
          "title": "Sample Ms",
          "type": "integer"
        },
        "source_api": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Source Api",
          "type": "object"
        },
        "subsystem": {
          "enum": [
            "claw",
            "arm",
            "drivetrain"
          ],
          "title": "Subsystem",
          "type": "string"
        },
        "values": {
          "$ref": "#/$defs/MotorApiValues"
        }
      },
      "required": [
        "device",
        "subsystem",
        "sample_ms",
        "values",
        "source_api"
      ],
      "title": "MotorApiSample",
      "type": "object"
    },
    "MotorApiValues": {
      "additionalProperties": false,
