          "title": "Efficiency Pct",
          "type": "number"
        },
        "position_deg": {
          "title": "Position Deg",
          "type": "number"
        },
        "power_w": {
          "title": "Power W",
          "type": "number"
        },
        "temperature_c": {
          "title": "Temperature C",
          "type": "number"
        },
        "torque_nm": {
          "title": "Torque Nm",
          "type": "number"
        },
        "velocity_rpm": {
          "title": "Velocity Rpm",
          "type": "number"
        }
      },
      "required": [
        "position_deg",
        "velocity_rpm",
        "current_amp",
        "power_w",
        "torque_nm",
        "efficiency_pct",
        "temperature_c"
      ],
      "title": "MotorApiValues",
      "type": "object"
    },
    "ScoreGap": {
      "additionalProperties": false,
      "properties": {
        "distance_error_m": {
          "title": "Distance Error M",
          "type": "number"
        },
        "success_correct": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Success Correct"
        }
      },
      "required": [
        "distance_error_m"
      ],
      "title": "ScoreGap",
      "type": "object"
    },
    "ScoreObserved": {
      "additionalProperties": false,
      "properties": {
        "ball_in_bin": {
          "title": "Ball In Bin",
          "type": "boolean"
        },
        "distance_from_bin_m": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Distance From Bin M"
        },
        "score_value": {
          "minimum": 0.0,
          "title": "Score Value",
          "type": "number"
        },
        "success": {
          "title": "Success",
          "type": "boolean"
        }
      },
      "required": [
        "ball_in_bin",
        "score_value",
        "success"
      ],
