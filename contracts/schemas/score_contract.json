      "type": "object"
    },
    "ScorePredicted": {
      "additionalProperties": false,
      "properties": {
        "distance_from_bin_m": {
          "minimum": 0.0,
          "title": "Distance From Bin M",
          "type": "number"
        },
        "success": {
          "title": "Success",
          "type": "boolean"
        }
      },
      "required": [
        "distance_from_bin_m",
        "success"
      ],
      "title": "ScorePredicted",
      "type": "object"
    },
    "VisionBlock": {
      "additionalProperties": false,
      "properties": {
        "apriltag_pose": {
          "anyOf": [
            {
              "$ref": "#/$defs/AprilTagPose"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "bbox_iou": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Bbox Iou"
        },
        "object_bbox": {
          "anyOf": [
            {
              "items": {
                "type": "integer"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Object Bbox"
        },
        "object_detected": {
          "title": "Object Detected",
          "type": "boolean"
        }
      },
      "required": [
        "object_detected"
      ],
      "title": "VisionBlock",
      "type": "object"
    }
  },
  "additionalProperties": true,
  "description": "Fully-typed `score` contract line \u2014 the typed successor to `ScoreContract`.\n\nSame envelope as `ContractLine`, but `predicted` / `gap` / `outcome` are the\ntyped score blocks and `task` is pinned to `\"score\"`. Use this when you want\nattribute access (`line.outcome.ball_in_bin`) and a schema that documents the\nscore fields; `ContractLine` itself still enforces the same blocks for a\n`task == \"score\"` line via the validator above.",
  "properties": {
    "gap": {
      "$ref": "#/$defs/ScoreGap"
    },
    "generation": {
      "title": "Generation",
      "type": "integer"
    },
    "motor_samples": {
      "items": {
        "$ref": "#/$defs/MotorApiSample"
      },
      "minItems": 1,
      "title": "Motor Samples",
      "type": "array"
    },
    "outcome": {
      "$ref": "#/$defs/ScoreObserved"
    },
    "predicted": {
      "$ref": "#/$defs/ScorePredicted"
    },
    "round": {
      "title": "Round",
      "type": "integer"
    },
    "schema_version": {
      "const": "1.0",
      "default": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "session_id": {
      "title": "Session Id",
      "type": "string"
    },
    "source": {
      "anyOf": [
        {
          "$ref": "#/$defs/ContractSource"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "task": {
      "const": "score",
      "default": "score",
      "title": "Task",
      "type": "string"
    },
    "vision": {
      "anyOf": [
        {
          "$ref": "#/$defs/VisionBlock"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    }
  },
  "required": [
    "session_id",
    "generation",
    "round",
    "motor_samples",
    "predicted",
    "gap",
    "outcome"
  ],
  "title": "ScoreContractLine",
  "type": "object"
}
