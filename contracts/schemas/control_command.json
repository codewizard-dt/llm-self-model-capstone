        "sent_ms": {
          "minimum": 0,
          "title": "Sent Ms",
          "type": "integer"
        },
        "seq": {
          "exclusiveMaximum": 4294967296,
          "minimum": 0,
          "title": "Seq",
          "type": "integer"
        },
        "ttl_ms": {
          "maximum": 5000,
          "minimum": 1,
