  "oneOf": [
    {
      "discriminator": {
        "mapping": {
          "arm": "#/$defs/ArmCommand",
          "claw": "#/$defs/ClawCommand",
          "drive": "#/$defs/DriveCommand",
          "flywheel": "#/$defs/FlywheelCommand",
