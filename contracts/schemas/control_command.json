{
  "$defs": {
    "ArmCommand": {
      "additionalProperties": false,
      "description": "Arm verb \u2014 absolute physical joint angle in degrees, optional vel_rpm.\n\n`deg` is the arm-joint angle (0\u00b0 stowed/down, ~90\u00b0 raised), not a motor\nencoder count; the Brain maps it to encoder targets per build. See the\nARM_DEG_MIN/MAX note above for the as-built calibration.",
      "properties": {
        "cmd": {
          "const": "arm",
          "default": "arm",
          "title": "Cmd",
          "type": "string"
        },
        "deg": {
          "maximum": 90.0,
          "minimum": 0.0,
          "title": "Deg",
          "type": "number"
        },
        "sent_ms": {
          "minimum": 0,
          "title": "Sent Ms",
          "type": "integer"
        },
        "seq": {
          "exclusiveMaximum": 4294967296,
          "minimum": 0,
          "title": "Seq",
          "type": "integer"
        },
        "ttl_ms": {
          "maximum": 5000,
          "minimum": 1,
          "title": "Ttl Ms",
          "type": "integer"
        },
        "type": {
          "const": "cmd",
          "default": "cmd",
          "title": "Type",
          "type": "string"
        },
        "v": {
          "const": 1,
          "default": 1,
          "title": "V",
          "type": "integer"
        },
        "vel_rpm": {
          "anyOf": [
            {
              "maximum": 600.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Vel Rpm"
        }
      },
      "required": [
        "seq",
        "sent_ms",
        "ttl_ms",
        "deg"
      ],
      "title": "ArmCommand",
      "type": "object"
    },
    "ClawCommand": {
      "additionalProperties": false,
      "description": "Claw verb \u2014 open/close, optional grip force.",
      "properties": {
        "cmd": {
          "const": "claw",
          "default": "claw",
          "title": "Cmd",
          "type": "string"
        },
        "grip_force_N": {
          "anyOf": [
            {
              "maximum": 100.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Grip Force N"
        },
        "sent_ms": {
          "minimum": 0,
          "title": "Sent Ms",
          "type": "integer"
        },
        "seq": {
          "exclusiveMaximum": 4294967296,
          "minimum": 0,
          "title": "Seq",
          "type": "integer"
        },
        "state": {
          "enum": [
            "open",
            "close"
          ],
          "title": "State",
          "type": "string"
        },
        "ttl_ms": {
          "maximum": 5000,
          "minimum": 1,
          "title": "Ttl Ms",
          "type": "integer"
        },
        "type": {
          "const": "cmd",
          "default": "cmd",
          "title": "Type",
          "type": "string"
        },
        "v": {
          "const": 1,
          "default": 1,
          "title": "V",
          "type": "integer"
        }
      },
      "required": [
        "seq",
        "sent_ms",
        "ttl_ms",
        "state"
      ],
      "title": "ClawCommand",
      "type": "object"
    },
    "DriveCommand": {
      "additionalProperties": false,
      "description": "Drive verb \u2014 planar velocity command.\n\n`vy` is wire-locked to 0 (D12): every post-PR-#18 buildable config uses\n`front_omni+rear_standard`, so a holonomic axis is structurally inapplicable\ntoday. Keeping the field forward-compats a future holonomic kit \u2014 drop the\n`le=0` bound, no wire addition.",
      "properties": {
        "cmd": {
          "const": "drive",
          "default": "drive",
          "title": "Cmd",
          "type": "string"
        },
        "omega": {
          "maximum": 0.6,
          "minimum": -0.6,
          "title": "Omega",
          "type": "number"
        },
        "sent_ms": {
          "minimum": 0,
          "title": "Sent Ms",
          "type": "integer"
        },
        "seq": {
          "exclusiveMaximum": 4294967296,
          "minimum": 0,
          "title": "Seq",
          "type": "integer"
        },
        "ttl_ms": {
          "maximum": 5000,
          "minimum": 1,
          "title": "Ttl Ms",
          "type": "integer"
        },
        "type": {
          "const": "cmd",
          "default": "cmd",
          "title": "Type",
          "type": "string"
        },
        "v": {
          "const": 1,
          "default": 1,
          "title": "V",
          "type": "integer"
        },
        "vx": {
          "maximum": 0.35,
          "minimum": -0.35,
          "title": "Vx",
          "type": "number"
        },
        "vy": {
          "default": 0.0,
          "maximum": 0.0,
          "minimum": 0.0,
          "title": "Vy",
          "type": "number"
        }
      },
      "required": [
        "seq",
        "sent_ms",
        "ttl_ms",
        "vx",
        "omega"
      ],
      "title": "DriveCommand",
      "type": "object"
    },
    "FlywheelCommand": {
      "additionalProperties": false,
